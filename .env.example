# AutoTabML Studio – Environment Variables
# Copy this file to .env for local overrides.
# NEVER commit .env to version control.

# Non-secret app settings use the AUTOTABML_ prefix.
# Nested settings use a double underscore, for example AUTOTABML_MLFLOW__TRACKING_URI.
# Provider API keys remain unprefixed because the provider clients read them directly.

# --- Provider API Keys (read directly by provider clients, no prefix) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# --- Local Runtime Defaults ---
# AUTOTABML_WORKSPACE_MODE=dashboard
# AUTOTABML_EXECUTION__BACKEND=local
# AUTOTABML_MLFLOW__TRACKING_URI=sqlite:///artifacts/mlflow/mlflow.db
# AUTOTABML_MLFLOW__REGISTRY_URI=sqlite:///artifacts/mlflow/mlflow.db
# AUTOTABML_ARTIFACTS__ROOT_DIR=artifacts
# AUTOTABML_DATABASE__PATH=artifacts/app/app_metadata.sqlite3
# AUTOTABML_OLLAMA_BASE_URL=http://localhost:11434
# AUTOTABML_LOG_LEVEL=INFO

# --- Optional provider base URL override ---
# AUTOTABML_PROVIDER__BASE_URL=https://api.example.com/v1

# --- Direct Ollama fallback ---
# The provider layer also honors OLLAMA_BASE_URL when it is used directly.
# OLLAMA_BASE_URL=http://localhost:11434
